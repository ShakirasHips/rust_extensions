[
  // ─── Build ───────────────────────────────────────────────────────────────
  {
    "label": "cargo: build (debug)",
    "command": "cargo build",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: build (release)",
    "command": "cargo build --release",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: build (all features)",
    "command": "cargo build --all-features",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: check",
    "command": "cargo check --all-targets",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },

  // ─── Test ────────────────────────────────────────────────────────────────
  {
    "label": "cargo: test (all)",
    "command": "cargo test",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "all",
  },
  {
    "label": "cargo: test (all features)",
    "command": "cargo test --all-features",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "all",
  },
  {
    "label": "cargo: test (current file)",
    "command": "cargo test $ZED_STEM",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "current",
    "tags": ["rust-test"],
  },
  {
    "label": "cargo: test (nocapture)",
    "command": "cargo test -- --nocapture",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "all",
  },
  {
    "label": "cargo: test (doc tests)",
    "command": "cargo test --doc",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "all",
  },

  // ─── Run ─────────────────────────────────────────────────────────────────
  {
    "label": "cargo: run (debug)",
    "command": "cargo run",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "all",
  },
  {
    "label": "cargo: run (release)",
    "command": "cargo run --release",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "all",
  },
  {
    "label": "cargo: run (example)",
    "command": "cargo run --example $ZED_STEM",
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "current",
    "tags": ["rust-example"],
  },

  // ─── Lint ────────────────────────────────────────────────────────────────
  {
    "label": "cargo: clippy",
    "command": "cargo clippy --all-targets --all-features",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: clippy (fix)",
    "command": "cargo clippy --all-targets --all-features --fix --allow-staged",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: clippy (deny warnings)",
    "command": "cargo clippy --all-targets --all-features -- -D warnings",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: fmt",
    "command": "cargo fmt",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "no_focus",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: fmt (check)",
    "command": "cargo fmt --check",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },

  // ─── Docs ────────────────────────────────────────────────────────────────
  {
    "label": "cargo: doc",
    "command": "cargo doc --no-deps --all-features",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },
  {
    "label": "cargo: doc (open)",
    "command": "cargo doc --no-deps --all-features --open",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "no_focus",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "all",
  },

  // ─── Workspace / Housekeeping ─────────────────────────────────────────────
  {
    "label": "cargo: clean",
    "command": "cargo clean",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "none",
  },
  {
    "label": "cargo: update deps",
    "command": "cargo update",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success",
    "save": "none",
  },
  {
    "label": "cargo: audit",
    "command": "cargo audit",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "none",
  },
  {
    "label": "cargo: watch (check)",
    "command": "cargo watch -x check",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "none",
  },
  {
    "label": "cargo: watch (test)",
    "command": "cargo watch -x test",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "never",
    "save": "none",
  },
]
